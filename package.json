{
  "name": "cairngraph",
  "version": "0.3.0",
  "private": false,
  "description": "Grounded, traceable, blast-radius-aware visual navigation for the CairnStone graph.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "candidate": "npm run check && npm test",
    "worker:check": "tsc --noEmit -p tsconfig.json",
    "worker:dev": "wrangler dev workers/cairngraph-worker/src/index.ts --config workers/cairngraph-worker/wrangler.toml",
    "worker:deploy:dry": "wrangler deploy --dry-run --config workers/cairngraph-worker/wrangler.toml",
    "verify:live": "node scripts/verify-live-worker.mjs",
    "verify:live-chain": "node scripts/verify-live-chain.mjs",
    "verify:provider-config": "node scripts/check-live-provider-config.mjs"
  },
  "keywords": [
    "cairnstone",
    "graph",
    "visualization",
    "blast-radius",
    "mermaid",
    "cloudflare"
  ],
  "author": "nothinginfinity",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.4",
    "wrangler": "^3.78.12"
  }
}
